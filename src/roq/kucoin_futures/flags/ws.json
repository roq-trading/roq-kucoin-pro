{
  "name": "roq/kucoin_futures/flags/WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "default": "wss://wsapi.kucoin.com/v1/private",
      "description": "Exchange end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "15s",
      "description": "Request timeout"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "std/uint32",
      "required": true,
      "default": 16,
      "description": "Maximum number of symbols per connection"
    },
    {
      "name": "subscribe_ticker_v2",
      "type": "std/bool",
      "default": false,
      "description": "Subscribe ticker v2?"
    },
    {
      "name": "mbp_request_delay",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "500ms",
      "description": "Request delay"
    },
    {
      "name": "mbp_request_max_retries",
      "type": "std/uint32",
      "default": 0,
      "description": "Request max retries"
    }
  ]
}
